# syntax=docker/dockerfile:1.7
# Drederick Jeopardy CTF sandbox image.
#
# Base: ubuntu:24.04 (python 3.12). Single non-root user `ctf` (uid 1000).
# Workdir /home/ctf/work (chmod 0777). No sudo. Entry: bash with TTY.
#
# The LLM solver executes arbitrary shell inside this container; the
# container itself is the isolation boundary. Network access is controlled
# by the harness via `docker run --network ...`.

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_ROOT_USER_ACTION=ignore \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_BREAK_SYSTEM_PACKAGES=1

# -----------------------------------------------------------------------------
# 1. APT: core toolchain, binary/reverse, forensics, stego, web, network, misc.
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    # base / QoL
    bash-completion bsdmainutils build-essential ca-certificates cmake curl \
    fd-find file git hexyl ipython3 jq less make python3 python3-dev \
    python3-pip python3-venv ripgrep screen tmux tree vim wget \
    # binary / reverse
    binwalk foremost gdb gdb-multiarch ltrace patchelf radare2 strace \
    upx-ucl xxd \
    # pwn helpers (native)
    libcapstone-dev libunicorn-dev libkeystone-dev libseccomp-dev \
    seccomp \
    # crypto (native)
    libgmp-dev libmpfr-dev libmpc-dev libssl-dev openssl sagemath \
    # forensics
    exiftool libimage-exiftool-perl scalpel sleuthkit testdisk \
    # stego
    imagemagick pngcheck steghide stegseek tesseract-ocr \
    exiftran exiv2 zbar-tools \
    # web
    ffuf gobuster nmap sqlmap wfuzz \
    # network
    dnsutils netcat-traditional socat tcpdump tshark \
    # media
    ffmpeg sox \
    # ruby (for zsteg) and java (for stegsolve jar)
    ruby ruby-dev default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# 2. GDB plugins: pwndbg + peda (git, no heavy build). Pick pwndbg by default;
#    peda is available via `gdb -x /opt/peda/peda.py`.
# -----------------------------------------------------------------------------
RUN set -eux; \
    git clone --depth=1 https://github.com/pwndbg/pwndbg /opt/pwndbg || true; \
    if [ -d /opt/pwndbg ]; then \
      (cd /opt/pwndbg && ./setup.sh || true); \
    fi; \
    git clone --depth=1 https://github.com/longld/peda.git /opt/peda || true; \
    echo 'source /opt/pwndbg/gdbinit.py' > /etc/gdb/gdbinit || true

# -----------------------------------------------------------------------------
# 3. Python toolchain: pwntools, angr, ropper, z3, sympy, crypto, forensics,
#    web, ML helpers. Single pip invocation for layer efficiency.
# -----------------------------------------------------------------------------
RUN python3 -m pip install --no-cache-dir --break-system-packages \
    pwntools \
    angr \
    capstone \
    keystone-engine \
    unicorn \
    ropper \
    ROPgadget \
    pycryptodome \
    pycryptodomex \
    gmpy2 \
    sympy \
    z3-solver \
    primefac \
    factordb-pycli \
    volatility3 \
    hachoir \
    pillow \
    numpy \
    scipy \
    requests \
    httpx \
    flask \
    beautifulsoup4 \
    lxml \
    playwright \
    && true

# Torch CPU wheel is large; install separately so it can fail independently
# on platforms where the wheel isn't published.
RUN python3 -m pip install --no-cache-dir --break-system-packages \
    --index-url https://download.pytorch.org/whl/cpu torch \
    || echo "torch-cpu wheel unavailable; skipping"

# Playwright chromium (optional; best-effort).
RUN python3 -m playwright install --with-deps chromium || true

# -----------------------------------------------------------------------------
# 4. Ruby gems (zsteg) and external git tools.
# -----------------------------------------------------------------------------
RUN gem install --no-document zsteg || true

RUN set -eux; \
    mkdir -p /opt; \
    git clone --depth=1 https://github.com/RsaCtfTool/RsaCtfTool /opt/RsaCtfTool || true; \
    if [ -d /opt/RsaCtfTool ]; then \
      python3 -m pip install --no-cache-dir --break-system-packages -r /opt/RsaCtfTool/requirements.txt || true; \
      ln -sf /opt/RsaCtfTool/RsaCtfTool.py /usr/local/bin/RsaCtfTool; \
    fi; \
    git clone --depth=1 https://github.com/david942j/one_gadget /opt/one_gadget || true; \
    if [ -d /opt/one_gadget ]; then \
      (cd /opt/one_gadget && gem build one_gadget.gemspec && gem install ./one_gadget-*.gem --no-document) || true; \
    fi; \
    git clone --depth=1 https://github.com/david942j/seccomp-tools /opt/seccomp-tools || true; \
    if [ -d /opt/seccomp-tools ]; then \
      (cd /opt/seccomp-tools && gem build seccomp-tools.gemspec && gem install ./seccomp-tools-*.gem --no-document) || true; \
    fi; \
    git clone --depth=1 https://github.com/niklasb/libc-database /opt/libc-database || true; \
    git clone --depth=1 https://github.com/zardus/preeny /opt/preeny || true; \
    mkdir -p /opt/stegsolve && \
      wget -q http://www.caesum.com/handbook/Stegsolve.jar -O /opt/stegsolve/stegsolve.jar || true; \
    printf '#!/bin/sh\nexec java -jar /opt/stegsolve/stegsolve.jar "$@"\n' > /usr/local/bin/stegsolve; \
    chmod +x /usr/local/bin/stegsolve

# -----------------------------------------------------------------------------
# 5. Convenience symlinks (fd, nc-traditional already default).
# -----------------------------------------------------------------------------
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd || true

# -----------------------------------------------------------------------------
# 6. Non-root user `ctf` (uid/gid 1000). No sudo. Workdir writable by anyone.
# -----------------------------------------------------------------------------
RUN groupadd -g 1000 ctf \
 && useradd -m -u 1000 -g 1000 -s /bin/bash ctf \
 && mkdir -p /home/ctf/work \
 && chown -R ctf:ctf /home/ctf \
 && chmod 0777 /home/ctf/work

# -----------------------------------------------------------------------------
# 7. Healthcheck.
# -----------------------------------------------------------------------------
COPY --chmod=0755 <<'SH' /healthcheck.sh
#!/usr/bin/env bash
set -e
python3 -c "import pwn, angr, Crypto, volatility3" >/dev/null
r2 -v >/dev/null
echo OK
SH

HEALTHCHECK --interval=10s --timeout=10s --start-period=15s --retries=3 \
  CMD /healthcheck.sh || exit 1

USER ctf
WORKDIR /home/ctf/work

# Entry: interactive bash. Harness typically overrides with `sleep infinity`
# for long-running sessions and drives the container via `docker exec`.
ENTRYPOINT ["/bin/bash"]

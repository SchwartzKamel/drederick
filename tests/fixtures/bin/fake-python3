#!/bin/sh
# Replay stub for tests/fixtures/bin/fake-python3 — emits a deterministic
# Python version string so doctor checks don't depend on the host's Python.
# This is consumed only via IProcessRunner stubs; never actually exec'd.
case "$1" in
  --version)
    echo "Python 3.10.12"
    exit 0
    ;;
  -c)
    # Best-effort: succeed for plain "import flask, sqlalchemy, cryptography".
    exit 0
    ;;
  *)
    echo "fake-python3: unsupported arg: $*" >&2
    exit 2
    ;;
esac

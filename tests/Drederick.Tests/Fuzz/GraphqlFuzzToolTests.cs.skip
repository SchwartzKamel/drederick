using System.Net;
using System.Text;
using Drederick.Audit;
using Drederick.Doctor;
using Drederick.Recon.Fuzz;
using Drederick.Scope;
using Xunit;

namespace Drederick.Tests.Fuzz;

public sealed class GraphqlFuzzToolTests
{
    private const string InScopeHost = "192.168.1.100";
    private const string OutOfScopeHost = "8.8.8.8";

    private static Scope.Scope CreateScope()
    {
        return new Scope.Scope(
            Targets: [$"{InScopeHost}/32"],
            AllowBroad: false,
            LabMode: true);
    }

    private static AuditLog CreateAuditLog()
    {
        // In-memory audit log for tests
        var tempPath = Path.Combine(Path.GetTempPath(), $"audit-{Guid.NewGuid()}.jsonl");
        return new AuditLog(tempPath);
    }

    [Fact]
    public async Task Throws_When_Url_OutOfScope()
    {
        var scope = CreateScope();
        var audit = CreateAuditLog();
        var tool = new GraphqlFuzzTool(scope, audit);

        var outOfScopeUrl = $"http://{OutOfScopeHost}/graphql";

        await Assert.ThrowsAsync<ScopeException>(
            async () => await tool.ProbeAsync(outOfScopeUrl));

        tool.Dispose();
    }

    [Theory]
    [InlineData("not-a-url")]
    [InlineData("ftp://example.com/graphql")]
    [InlineData("file:///etc/passwd")]
    [InlineData("javascript:alert(1)")]
    public async Task Throws_When_Url_Invalid(string invalidUrl)
    {
        var scope = CreateScope();
        var audit = CreateAuditLog();
        var tool = new GraphqlFuzzTool(scope, audit);

        await Assert.ThrowsAsync<ArgumentException>(
            async () => await tool.ProbeAsync(invalidUrl));

        tool.Dispose();
    }

    [Fact]
    public async Task Detects_Introspection_Enabled()
    {
        var scope = CreateScope();
        var audit = CreateAuditLog();

        // Load fixture
        var fixturePath = Path.Combine(
            "tests", "Drederick.Tests", "Fuzz", "fixtures", "graphql-introspection-enabled.json");
        var fixtureJson = await File.ReadAllTextAsync(fixturePath);

        // Fake HttpClient that returns the fixture
        var handler = new GraphqlFakeHttpMessageHandler(fixtureJson);
        var httpClient = new HttpClient(handler);

        var tool = new GraphqlFuzzTool(scope, audit, httpClient: httpClient);

        var result = await tool.ProbeAsync($"http://{InScopeHost}/graphql");

        Assert.True(result.IntrospectionEnabled);
        Assert.NotNull(result.SchemaDigest);
        Assert.NotEmpty(result.SchemaDigest);
        Assert.Contains("user", result.Queries);
        Assert.Contains("users", result.Queries);
        Assert.Contains("posts", result.Queries);
        Assert.Contains("createUser", result.Mutations);
        Assert.Contains("deleteUser", result.Mutations);
        Assert.Contains("updatePassword", result.Mutations);
        Assert.Null(result.Error);

        tool.Dispose();
    }

    [Fact]
    public async Task Handles_Introspection_Disabled_Gracefully()
    {
        var scope = CreateScope();
        var audit = CreateAuditLog();

        // Load fixture
        var fixturePath = Path.Combine(
            "tests", "Drederick.Tests", "Fuzz", "fixtures", "graphql-introspection-blocked.json");
        var fixtureJson = await File.ReadAllTextAsync(fixturePath);

        // Fake HttpClient that returns the fixture
        var handler = new GraphqlFakeHttpMessageHandler(fixtureJson);
        var httpClient = new HttpClient(handler);

        var tool = new GraphqlFuzzTool(scope, audit, httpClient: httpClient);

        var result = await tool.ProbeAsync($"http://{InScopeHost}/graphql");

        Assert.False(result.IntrospectionEnabled);
        Assert.Null(result.SchemaDigest);
        Assert.Empty(result.Mutations);
        Assert.Empty(result.Queries);
        Assert.Null(result.Error);

        tool.Dispose();
    }

    [Fact]
    public async Task Handles_GraphqlCop_Missing_Gracefully()
    {
        var scope = CreateScope();
        var audit = CreateAuditLog();

        // Load fixture
        var fixturePath = Path.Combine(
            "tests", "Drederick.Tests", "Fuzz", "fixtures", "graphql-introspection-enabled.json");
        var fixtureJson = await File.ReadAllTextAsync(fixturePath);

        // Fake HttpClient
        var handler = new GraphqlFakeHttpMessageHandler(fixtureJson);
        var httpClient = new HttpClient(handler);

        // Fake ProcessRunner that returns exit 127 (command not found)
        var runner = new FakeProcessRunner(exitCode: 127, stdout: "", stderr: "graphql-cop: command not found");

        var tool = new GraphqlFuzzTool(
            scope, audit, httpClient: httpClient, graphqlCopPath: "graphql-cop", runner: runner);

        var result = await tool.ProbeAsync($"http://{InScopeHost}/graphql");

        Assert.True(result.IntrospectionEnabled);
        Assert.Empty(result.CopFindings); // graphql-cop unavailable → empty findings
        Assert.Null(result.Error);

        tool.Dispose();
    }

    [Fact]
    public async Task Parses_GraphqlCop_Json_Output()
    {
        var scope = CreateScope();
        var audit = CreateAuditLog();

        // Load introspection fixture
        var introPath = Path.Combine(
            "tests", "Drederick.Tests", "Fuzz", "fixtures", "graphql-introspection-enabled.json");
        var introJson = await File.ReadAllTextAsync(introPath);

        // Load graphql-cop fixture
        var copPath = Path.Combine(
            "tests", "Drederick.Tests", "Fuzz", "fixtures", "graphql-cop-output.json");
        var copJson = await File.ReadAllTextAsync(copPath);

        // Fake HttpClient
        var handler = new GraphqlFakeHttpMessageHandler(introJson);
        var httpClient = new HttpClient(handler);

        // Fake ProcessRunner that returns the cop fixture
        var runner = new FakeProcessRunner(exitCode: 0, stdout: copJson, stderr: "");

        var tool = new GraphqlFuzzTool(
            scope, audit, httpClient: httpClient, graphqlCopPath: "graphql-cop", runner: runner);

        var result = await tool.ProbeAsync($"http://{InScopeHost}/graphql");

        Assert.True(result.IntrospectionEnabled);
        Assert.NotEmpty(result.CopFindings);
        Assert.Equal(4, result.CopFindings.Count);
        Assert.Contains(result.CopFindings, f => f.Contains("[HIGH] Alias Overloading"));
        Assert.Contains(result.CopFindings, f => f.Contains("[MEDIUM] Batch Query Support"));
        Assert.Contains(result.CopFindings, f => f.Contains("[LOW] Field Suggestions"));
        Assert.Contains(result.CopFindings, f => f.Contains("[HIGH] Missing CSRF Protection"));
        Assert.Null(result.Error);

        tool.Dispose();
    }

    [Fact]
    public async Task SchemaDigest_Is_Stable_Across_Reorderings()
    {
        var scope = CreateScope();
        var audit1 = CreateAuditLog();
        var audit2 = CreateAuditLog();

        // Same schema, potentially different JSON order (but in practice our fixture is stable)
        // We'll test that the same fixture produces the same digest twice
        var fixturePath = Path.Combine(
            "tests", "Drederick.Tests", "Fuzz", "fixtures", "graphql-introspection-enabled.json");
        var fixtureJson = await File.ReadAllTextAsync(fixturePath);

        // First run
        var handler1 = new GraphqlFakeHttpMessageHandler(fixtureJson);
        var httpClient1 = new HttpClient(handler1);
        var tool1 = new GraphqlFuzzTool(scope, audit1, httpClient: httpClient1);
        var result1 = await tool1.ProbeAsync($"http://{InScopeHost}/graphql");

        // Second run (same fixture)
        var handler2 = new GraphqlFakeHttpMessageHandler(fixtureJson);
        var httpClient2 = new HttpClient(handler2);
        var tool2 = new GraphqlFuzzTool(scope, audit2, httpClient: httpClient2);
        var result2 = await tool2.ProbeAsync($"http://{InScopeHost}/graphql");

        Assert.NotNull(result1.SchemaDigest);
        Assert.NotNull(result2.SchemaDigest);
        Assert.Equal(result1.SchemaDigest, result2.SchemaDigest);

        tool1.Dispose();
        tool2.Dispose();
    }

    [Fact]
    public async Task Audit_Records_Start_And_Finish_Events()
    {
        var scope = CreateScope();
        var tempPath = Path.Combine(Path.GetTempPath(), $"audit-{Guid.NewGuid()}.jsonl");
        var audit = new AuditLog(tempPath);

        // Load fixture
        var fixturePath = Path.Combine(
            "tests", "Drederick.Tests", "Fuzz", "fixtures", "graphql-introspection-enabled.json");
        var fixtureJson = await File.ReadAllTextAsync(fixturePath);

        var handler = new GraphqlFakeHttpMessageHandler(fixtureJson);
        var httpClient = new HttpClient(handler);

        var tool = new GraphqlFuzzTool(scope, audit, httpClient: httpClient);

        await tool.ProbeAsync($"http://{InScopeHost}/graphql");

        // Read audit log
        var lines = await File.ReadAllLinesAsync(tempPath);

        Assert.Contains(lines, l => l.Contains("graphql-fuzz.start"));
        Assert.Contains(lines, l => l.Contains("graphql-fuzz.finish"));

        // Cleanup
        tool.Dispose();
        if (File.Exists(tempPath))
        {
            File.Delete(tempPath);
        }
    }

    /// <summary>Fake HttpMessageHandler that returns a canned response.</summary>
    private sealed class GraphqlFakeHttpMessageHandler : HttpMessageHandler
    {
        private readonly string _responseBody;

        public GraphqlFakeHttpMessageHandler(string responseBody)
        {
            _responseBody = responseBody;
        }

        protected override Task<HttpResponseMessage> SendAsync(
            HttpRequestMessage request,
            CancellationToken cancellationToken)
        {
            var response = new HttpResponseMessage(HttpStatusCode.OK)
            {
                Content = new StringContent(_responseBody, Encoding.UTF8, "application/json"),
            };
            return Task.FromResult(response);
        }
    }

    /// <summary>Fake ProcessRunner that returns canned output.</summary>
    private sealed class FakeProcessRunner : IProcessRunner
    {
        private readonly int _exitCode;
        private readonly string _stdout;
        private readonly string _stderr;

        public FakeProcessRunner(int exitCode, string stdout, string stderr)
        {
            _exitCode = exitCode;
            _stdout = stdout;
            _stderr = stderr;
        }

        public (int ExitCode, string StdOut, string StdErr) Run(
            string file, string arguments, int timeoutSeconds)
        {
            return (_exitCode, _stdout, _stderr);
        }

        public (int ExitCode, string StdOut, string StdErr) RunShell(
            string commandLine, int timeoutSeconds)
        {
            return (_exitCode, _stdout, _stderr);
        }
    }
}
